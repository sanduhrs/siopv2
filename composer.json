{
    "name": "openid4vc/siopv2",
    "description": "Structured PHP library for implementing a Self-Issued OpenID Provider v2",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-openssl": "*",
        "psr/clock": "^1.0",
        "psr/log": "^3.0",
        "web-token/jwt-framework": "^4.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.1",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "OpenID4VC\\SIOPv2\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenID4VC\\SIOPv2\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyze": "phpstan analyse",
        "test": "phpunit",
        "test:coverage": "phpunit -c phpunit.coverage.xml.dist --coverage-text --coverage-clover coverage.xml --coverage-html coverage",
        "lint": "phpcs --runtime-set ignore_warnings_on_exit 1",
        "lint:fix": "phpcbf --runtime-set ignore_warnings_on_exit 1"
    }
}
